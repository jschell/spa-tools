#!/bin/bash
# Regenerate index.html and README.md after each commit so last-modified dates
# stay current without requiring a manual `python update-tools.py` run.
#
# Setup (one-time, per clone):
#   git config core.hooksPath .githooks

# Guard against infinite recursion: the amend below triggers post-commit again.
if [ -n "$TOOLS_HOOK_RUNNING" ]; then exit 0; fi
export TOOLS_HOOK_RUNNING=1

ROOT="$(git rev-parse --show-toplevel)"
python3 "$ROOT/update-tools.py"

cd "$ROOT"

# Stage outputs that update-tools.py may have changed.
git add index.html README.md
# inject_last_modified also rewrites each tool's HTML file.
git add *.html 2>/dev/null || true

# Only amend if anything actually changed.
if git diff --cached --quiet; then
  exit 0
fi

git commit --amend --no-edit
